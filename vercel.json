{
  "version": 2,
  "builds": [
    {
      "src": "flask_simulation_app/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/flask_simulation_app/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "flask_simulation_app/app.py"
    }
  ]
}
